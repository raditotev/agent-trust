# Database
DATABASE_URL=postgresql+asyncpg://agent_trust:agent_trust@localhost:5432/agent_trust

# Redis
REDIS_URL=redis://localhost:6379/0

# Authentication
AUTH_PROVIDER=both

# AgentAuth MCP integration
AGENTAUTH_MCP_URL=https://agentauth.radi.pro/mcp
AGENTAUTH_ACCESS_TOKEN=

# Signing key
SIGNING_KEY_PATH=keys/service.key

# Scoring parameters
SCORE_HALF_LIFE_DAYS=90.0
DISPUTE_PENALTY=0.03
ATTESTATION_TTL_HOURS=24

# Transport
MCP_TRANSPORT=stdio
MCP_PORT=8000

# Logging
LOG_LEVEL=INFO
JSON_LOGS=false