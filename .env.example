# ── Runtime ────────────────────────────────────────────────────────────────────
# development | production  (production enforces TLS and loopback-only binding)
ENVIRONMENT=development

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agent_trust:agent_trust@localhost:5433/agent_trust

# Docker Compose only — used to initialise the postgres container
POSTGRES_DB=agent_trust
POSTGRES_USER=agent_trust
POSTGRES_PASSWORD=changeme

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:changeme@localhost:6380/0

# Docker Compose only — used to configure the redis container
REDIS_PASSWORD=changeme

# ── Authentication ─────────────────────────────────────────────────────────────
# agentauth | standalone | both
AUTH_PROVIDER=both

# ── AgentAuth MCP integration ──────────────────────────────────────────────────
AGENTAUTH_MCP_URL=https://agentauth.radi.pro/mcp
AGENTAUTH_ACCESS_TOKEN=

# ── Signing key ────────────────────────────────────────────────────────────────
SIGNING_KEY_PATH=keys/service.key
# Leave empty for an unencrypted key (dev only)
SIGNING_KEY_PASSWORD=

# ── MCP transport ──────────────────────────────────────────────────────────────
# stdio | streamable-http
MCP_TRANSPORT=stdio
MCP_PORT=8000

# TLS — required when ENVIRONMENT=production and MCP_TRANSPORT=streamable-http
TLS_CERT_PATH=
TLS_KEY_PATH=

# ── Scoring parameters ─────────────────────────────────────────────────────────
SCORE_HALF_LIFE_DAYS=90.0
DISPUTE_PENALTY=0.03
ATTESTATION_TTL_HOURS=24
ATTESTATION_CUMULATIVE_REVOCATION_THRESHOLD=0.10

# ── Dispute limits ─────────────────────────────────────────────────────────────
DISPUTE_FILER_DAILY_CAP=10
DISPUTE_FILER_OPEN_CAP=30

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_BASE=60
RATE_LIMIT_ROOT_MULTIPLIER=5.0
RATE_LIMIT_DELEGATED_MULTIPLIER=2.0
RATE_LIMIT_STANDALONE_MULTIPLIER=1.0
RATE_LIMIT_EPHEMERAL_MULTIPLIER=0.5
RATE_LIMIT_UNAUTHENTICATED=10

# ── Sybil detection ────────────────────────────────────────────────────────────
SYBIL_BURST_24H_THRESHOLD=20
SYBIL_BURST_7D_THRESHOLD=50
SYBIL_REPORT_VELOCITY_THRESHOLD=50

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Set true in production for structured JSON output
JSON_LOGS=false